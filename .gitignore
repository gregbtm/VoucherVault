# ignore virtual environment folder
venv/
.venv/

# ignore secret .env
**.env**

# ignore database
*.db
*.sqlite3

# ignore pyc files
*.pyc

# ignore secretsdump sess recovery
*sessionresume*

# ignore logs
/logs/
*.log
*.bak

# ignore file uploads
database/uploads/
database/imports/
database/documents/
database/backups/

# ignore stray media files manage.py test writes straight to database/ -
# Item.file uploads aren't wrapped in the DB transaction rollback tests
# otherwise get, so every run leaves a handful of throwaway images/PDFs
# sitting in the repo root's database/ directory
database/*.png
database/*.pdf
database/*.jpg
database/*.jpeg
encrypted.data

# ignore signed licenses
**license.txt

# ignore gpg stuff
.kbx
.gpg

# ignore potential hash files
.hashes
.pot

# ignore traefik certs and logs
acme.json
**/logs/**

# ignore file uploads
**/uploads/**
