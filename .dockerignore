# Ignore common Python and Django files
*.pyc
*.pyo
__pycache__

# Ignore environment files
.env

# Ignore Docker related files
Dockerfile
docker-compose.yml

# Ignore version control system directories
.git

# Ignore documentation files
documentation/
screenshots/

# ignore file uploads
database/uploads/

# Ignore GitHub Actions workflows for Docker images
.github

# Ignore local JS tooling (Phase 88's jsbuild stage does its own `npm ci`
# inside the build context, isolated from whatever's on the host)
node_modules/
dist/
