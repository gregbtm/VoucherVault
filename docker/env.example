# your FQDN or IP; used to define ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS
# multiple domains or IPs supported via comma as delimiter
DOMAIN=vouchervault.example.com

# set to True if you use a reverse proxy with tls; enables secure cookie flag and hsts
SECURE_COOKIES=False
# define the maximum session age in minutes
SESSION_COOKIE_AGE=30
# decide whether session cookie is invalidated on browser close
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# how many failed login attempts before an account is locked out; default is 5
#AXES_FAILURE_LIMIT=5
# how many hours a lockout lasts before the account can try again; default is 1
#AXES_COOLOFF_TIME_HOURS=1

# send notifications xx days prior expiry; default is 30
EXPIRY_THRESHOLD_DAYS=90
# "final reminder" window in days before expiry; default is 7
# (also used by the legacy Apprise-only expiry check as EXPIRY_LAST_NOTIFICATION_DAYS)
#EXPIRY_THRESHOLD_DAYS_FINAL=7

# define the timezone
TZ=Europe/Berlin

# console log verbosity: DEBUG, INFO, WARNING, ERROR. Server errors (5xx)
# and denied-access warnings always log regardless of this - lower it to
# DEBUG for noisier diagnostics, or raise it to reduce volume once a bug's
# been tracked down
#LOG_LEVEL=INFO

# comma-separated list of allowed sources for the csp `frame-ancestors` directive
#CSP_FRAME_ANCESTORS="https://other.example.tld:443"

# ------- NOTIFICATION RULES (ntfy / webhook / apprise / web push) --------
# default ntfy server pre-filled when a user creates a new ntfy rule;
# they can still point a rule at any other server, e.g. a self-hosted one
# such as https://ntfy.your-domain.example
#NTFY_DEFAULT_SERVER=https://ntfy.sh

# disabled unless both keys below are set; generate a pair with:
#   docker compose exec app python manage.py generate_vapid_keys
#WEBPUSH_VAPID_PUBLIC_KEY=
#WEBPUSH_VAPID_PRIVATE_KEY=
# optional; shown to push services as the VAPID contact claim
#WEBPUSH_VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# ------- PSQL DB ENVS --------
#DB_ENGINE=postgres
#POSTGRES_USER=vouchervault
#POSTGRES_PASSWORD=vouchervault
#POSTGRES_DB=vouchervault
#POSTGRES_HOST=vouchervault-psql

# ------- OPTIONAL OIDC AUTH --------
# Set to 'True' to enable OIDC authentication
#OIDC_ENABLED=True
# Decide whether login area triggers automatic OIDC login flow
#OIDC_AUTOLOGIN=False
# Set to 'True' to allow the creation of new users through OIDC
#OIDC_CREATE_USER=True
# The signing algorithm used by the OIDC provider (e.g., RS256, HS256)
#OIDC_RP_SIGN_ALGO=RS256
# URL of the JWKS endpoint for the OIDC provider
#OIDC_OP_JWKS_ENDPOINT=https://authentik.example.com/application/o/vouchervault/jwks/
# Client ID for your OIDC RP
#OIDC_RP_CLIENT_ID=vouchervault
# Client secret for your OIDC RP
#OIDC_RP_CLIENT_SECRET=super-secure-secret-key
# Authorization endpoint URL of the OIDC provider
#OIDC_OP_AUTHORIZATION_ENDPOINT=https://authentik.example.com/application/o/authorize/
# Token endpoint URL of the OIDC provider
#OIDC_OP_TOKEN_ENDPOINT=https://authentik.example.com/application/o/token/
# User info endpoint URL of the OIDC provider
#OIDC_OP_USER_ENDPOINT=https://authentik.example.com/application/o/userinfo/
# Alternative to the four endpoint vars above: point this at your provider's
# .well-known/openid-configuration document and the endpoints are read from
# it automatically. Any endpoint set explicitly above still wins over the
# discovered value.
#OIDC_DISCOVERY_URL=https://authentik.example.com/application/o/vouchervault/.well-known/openid-configuration

# ------- API --------
# Rate limit applied to write requests (POST/PUT/PATCH/DELETE) on the REST
# API; reads are never throttled. Format: "<count>/<period>" where period is
# second/minute/hour/day.
#API_WRITE_RATE_LIMIT=60/minute

# ------- MERCHANT LOGOS --------
# set to False to disable auto-fetching merchant logos (Clearbit, falling
# back to Google favicons) when an item is created/edited; default is True
#MERCHANT_LOGOS_ENABLED=True

# ------- OCR SCANNING --------
# disabled by default; set to "claude", "openai", or "tesseract" to enable
# the "Scan with AI" button on the create/edit item forms, which pre-fills
# fields from an uploaded photo of a voucher/coupon/card
#OCR_BACKEND=none
# required if OCR_BACKEND=claude; get one at https://console.anthropic.com/
#ANTHROPIC_API_KEY=
# optional; overrides the Claude model used for OCR extraction
#ANTHROPIC_OCR_MODEL=claude-sonnet-5
# required if OCR_BACKEND=openai; get one at https://platform.openai.com/api-keys
#OPENAI_API_KEY=
# optional; overrides the OpenAI model used for OCR extraction
#OPENAI_OCR_MODEL=gpt-4o-mini

# ------- APPLE WALLET (.pkpass) EXPORT --------
# disabled unless PKPASS_CERT_PATH is set; requires an Apple Developer
# Pass Type ID certificate (export as .p12) and Apple's WWDR intermediate
# certificate (download from https://www.apple.com/certificateauthority/).
# Mount both into the container and point these at the in-container paths,
# e.g. volumes: - ./volume-data/pkpass:/opt/app/pkpass:ro
#PKPASS_CERT_PATH=/opt/app/pkpass/pass-cert.p12
#PKPASS_CERT_PASSWORD=
#PKPASS_WWDR_CERT_PATH=/opt/app/pkpass/AppleWWDRCAG4.pem
# your Apple Developer Team ID
#PKPASS_TEAM_ID=
# your registered Pass Type ID, e.g. pass.com.example.vouchervault
#PKPASS_PASS_TYPE_ID=
# optional; shown as the pass's organization name
#PKPASS_ORGANIZATION_NAME=VoucherVault Plus+

# ------- GOOGLE WALLET EXPORT --------
# disabled unless both envs below are set; requires a Google Cloud service
# account with access to a Google Wallet API issuer account. This is a
# one-time setup for whoever runs the container, not something each user
# of the instance has to do. Full walkthrough (issuer account, service
# account key, and why a personal/family deployment can usually skip
# Google's "publishing access" review): docs/GOOGLE_WALLET_SETUP.md
# Mount the downloaded JSON key into the container, e.g.
# volumes: - ./volume-data/google-wallet:/opt/app/google-wallet:ro
#GOOGLE_WALLET_SERVICE_ACCOUNT_KEY_PATH=/opt/app/google-wallet/key.json
# your Google Wallet API issuer ID, shown in the Google Pay & Wallet Console
#GOOGLE_WALLET_ISSUER_ID=
# optional; a custom generic pass class ID. Defaults to "<issuer id>.vouchervault_generic"
#GOOGLE_WALLET_CLASS_ID=

# ------- UPDATE CHECK --------
# on by default; a periodic Celery task checks GitHub Releases for
# UPDATE_CHECK_REPO and shows a banner (superusers only) when a newer
# version exists. Set to False to disable outbound checks entirely.
#UPDATE_CHECK_ENABLED=True
# only change this if you're running a fork of a fork
#UPDATE_CHECK_REPO=gregbtm/VoucherVault

# ------- PORTAINER REDEPLOY WEBHOOK --------
# disabled unless set; if you're running this as a git-based Portainer
# stack (see docs/UPGRADE.md), setting this to your stack's Portainer
# webhook URL adds a "Redeploy now" button to the update-available banner
# above, for superusers. See docs/AUTO_DEPLOY.md for the full walkthrough,
# including a GitHub Action that can call the same webhook automatically
# on every push to main.
#PORTAINER_WEBHOOK_URL=

# ------- SCHEDULED LOCAL BACKUPS --------
# on by default; a nightly Celery task writes a rotating Full Backup zip
# per user to database/backups/<username>/. See docs/BACKUP_RESTORE.md
#SCHEDULED_BACKUP_ENABLED=True
# how many backups to keep per user before rotating out the oldest
#BACKUP_RETENTION_COUNT=7

# ------- OTHER OPTIONAL ENVS --------
# optional; if not defined, a secure secret is auto-generated
#SECRET_KEY=ChooseSuperSecretKey
# optional; only relevant if you use a custom port; used to define CSRF_TRUSTED_ORIGINS
#PORT=8000
# optional; only change if you use another redis container
#REDIS_URL=redis://redis:6379/0
# optional; overrides the version shown in the footer and used for the
# update check. Normally not needed - the VERSION file baked into the
# image (see docker/Dockerfile) is the source of truth.
#VERSION=
